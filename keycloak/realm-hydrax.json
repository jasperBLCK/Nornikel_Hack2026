{
  "realm": "hydrax",
  "enabled": true,
  "displayName": "HydraX Knowledge Map",
  "registrationAllowed": true,
  "registrationEmailAsUsername": false,
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": true,
  "bruteForceProtected": true,
  "failureFactor": 5,
  "waitIncrementSeconds": 60,
  "maxFailureWaitSeconds": 900,
  "accessTokenLifespan": 1800,
  "ssoSessionIdleTimeout": 28800,
  "defaultRoles": ["external_partner"],
  "roles": {
    "realm": [
      {"name": "admin", "description": "Администратор системы"},
      {"name": "project_manager", "description": "Руководитель проекта"},
      {"name": "analyst", "description": "Аналитик"},
      {"name": "researcher", "description": "Исследователь"},
      {"name": "external_partner", "description": "Внешний партнёр"}
    ]
  },
  "clients": [
    {
      "clientId": "hydrax-app",
      "name": "HydraX Web App",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:8000/*"],
      "webOrigins": ["http://localhost:8000"],
      "protocol": "openid-connect",
      "fullScopeAllowed": true
    }
  ],
  "users": [
    {
